#!/bin/sh
ROOT="$(git rev-parse --show-toplevel)"

# Capture staged files so we can re-stage after auto-formatting
STAGED=$(git diff --cached --name-only)

# Backend: auto-format Python with Ruff
cd "$ROOT/backend"
uv run ruff format .
uv run ruff check --fix .

# Frontend: auto-format with Prettier
cd "$ROOT/frontend"
npx prettier --write --ignore-unknown .

# Re-stage any files the formatters changed
if [ -n "$STAGED" ]; then
  cd "$ROOT"
  echo "$STAGED" | xargs git add 2>/dev/null || true
fi

# Frontend: lint with ESLint (fails commit on errors)
cd "$ROOT/frontend"
npm run lint
